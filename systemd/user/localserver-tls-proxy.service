[Unit]
Description=Caddy TLS proxy compose stack
Documentation=https://github.com/darraghog/localserver-config
Wants=network-online.target
After=network-online.target
ConditionPathExists=__REPO_ROOT__/certs/server.pem

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=PATH=__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=__REPO_ROOT__/scripts/start-stack.sh tls-proxy up
ExecStop=__REPO_ROOT__/scripts/start-stack.sh tls-proxy down

[Install]
WantedBy=default.target
