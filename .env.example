# Copy to .env and fill in values before deploying.
# .env is gitignored — never commit it.

# n8n admin password (required)
N8N_BASIC_AUTH_PASSWORD=

# n8n encryption key for stored credentials (required)
# Generate with: openssl rand -hex 32
# WARNING: if you lose this key, all saved credentials in n8n become unrecoverable
N8N_ENCRYPTION_KEY=
